views:
  - type: cards
    name: Cards
    filters:
      and:
        - |-
          file.inFolder(this.file.folder) &&
          file.folder == this.file.folder &&
          !file.path.endsWith(".base") &&
          file.basename != this.file.folder.split("/")[this.file.folder.split("/").length - 1]
    groupBy:
      property: type
      direction: ASC
    order:
      - file.name
    image: note.image
